<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Used during app launch -->
    <style name="LaunchTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor" tools:targetApi="l">#000000</item>
    </style>

    <!-- Main app theme (used by Stripe) -->
    <style name="NormalTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#6200EE</item>
        <item name="colorPrimaryVariant">#3700B3</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#03DAC6</item>
        <item name="colorSecondaryVariant">#018786</item>
        <item name="colorOnSecondary">#000000</item>
    </style>

    <!-- Optional wrapper if needed -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar" />
</resources>
